{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/datadog/refs/heads/main/json-schema/datadog-metrics-metric-payload-schema.json",
  "title": "MetricPayload",
  "description": "The payload containing one or more metric series to submit",
  "type": "object",
  "properties": {
    "series": {
      "type": "array",
      "description": "List of metric series to submit in this payload",
      "items": {
        "$ref": "#/components/schemas/MetricSeries"
      }
    }
  },
  "required": [
    "series"
  ]
}