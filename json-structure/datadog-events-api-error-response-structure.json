{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/datadog/refs/heads/main/json-structure/datadog-events-api-error-response-structure.json",
  "name": "APIErrorResponse",
  "description": "Standard API error response returned for failed requests",
  "type": "object",
  "properties": {
    "errors": {
      "type": "array",
      "description": "List of error messages describing the failure",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "errors"
  ]
}