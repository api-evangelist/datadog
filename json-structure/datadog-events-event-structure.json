{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/datadog/refs/heads/main/json-structure/datadog-events-event-structure.json",
  "name": "Event",
  "description": "A single event from the Datadog Events Explorer",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "The unique string identifier of the event",
      "example": "abc-123-def"
    },
    "type": {
      "type": "string",
      "description": "The resource type identifier (always 'event')",
      "example": "metric alert"
    },
    "attributes": {
      "$ref": "#/components/schemas/EventAttributes"
    }
  }
}